class BytecodeFrame extends FrameObject {
	var currentInstr: Maybe<Opcode> = Maybe.Nothing;
	var associatedFunc: FunctionProfileMetadata;
	// total time spent(in microseconds) by this frame to execute other function/method frames
	var calleeExecutionTime: int = 0;

	new(prev: FrameObject, code: CodeObject, args: Array<(string, Object)>, nonlocalArgs: Array<(string, Object)>) super(prev, code, args) {
		if (code != null) {
			def bytecode = Code.Bytecode.!(code.code).bytecode;
			locals = Array.new(bytecode.locals.length);
			for (i < args.length) {
				locals[i] = args[i].1;
			}
			// XXX some slow unification here, which might lead to some nonlocals not being used from the args?
			nonlocals = Array.new(bytecode.nonlocals.length);
			for (i < nonlocals.length) {
				def id = bytecode.nonlocals[i];
				// search for id in nonlocal args
				var found: bool;
				for (p in nonlocalArgs) {
					if (Strings.equal(id, p.0)) {
						nonlocals[i] = p.1;
						found = true;
						break;
					}
				}
				if (!found) {
					// might this ever happen?
					System.error("eval error", "unable to unify nonlocal arguments");
				}
			}
		} else {
			locals = Array.new(0);
			nonlocals = Array.new(0);
		}
	}

	def var locals: Array<Object>;
	def var nonlocals: Array<Object>;

	def stack: ArrayStack<Object> = ArrayStack.new();
	/* This is a handler stack which stores structure about exceptions:
	 *   (a, b)
	 *   where
	 *     a = absolute pc of handler
	 *     b = absolute size of stack (i.e. pop other things until you restore stack state)
	 */
	def handlers: ArrayStack<(int, int)> = ArrayStack.new();

	def eval() {
		def v = evalBytecode(Code.Bytecode.!(code.code).bytecode);
		if (!isAborting())
			result = Result.OK(v);
	}

	def evalCode(code: CodeObject) -> Object {
		stack.clear();
		def v = evalBytecode(Code.Bytecode.!(code.code).bytecode);
		if (!isAborting())
			result = Result.OK(v);
		return v;
	}

	/* BYTECODE EVALUATOR */
	def evalBytecode(b: Bytecode) -> Object {
		def code       = b.instrs;
		def strings    = b.stringPool;
		def classholes = b.classPool;
		def funcholes  = b.funcPool;
		def constants  = b.constPool;
		def source     = b.sourceMap;
		
		if (CiceroOptions.traceBytecodeEvaluation) {
			System.puts("Evaluating bytecode:\n");
			System.puts(Strings.format1("Number of locals: %d\n", locals.length));
			b.inspect();
			System.puts("==\n");
		}

		var pc = 0;
		var dispatchStartTime : int = System.ticksNs(); 
		var opExecTime : int;

		while (pc < code.length || isExn()) {
			if (CiceroOptions.sanityChecks)
				if ((pc & 0b11) != 0) System.error("eval error", Strings.format1("unaligned pc access: %d", pc));

			// if frame is in an exceptional state, try to handle it!
			// Should this go after the handlers?
 			if (isExn()) {
 				if (handlers.empty()) {
 					if (CiceroOptions.traceBytecodeEvaluation) System.puts("returned with exception\n");
 					return null;
 				}
 				def p = handlers.pop();
 				pc = p.0;
 				while (stack.top != p.1)
 					stack.pop();
 				// push error value
 				stack.push(getExn());
 				resetExn();
 			}

			// Fetch
			def bytecode = Ref<Instruction>.at(code, pc);
			loc = source[pc >> 2];

			/* Inline caches */
			var cache: Pair<ClassObject, int>;
 
 			def opcode = bytecode.opcode;
 			def opcode_pc = pc;
			def operand  = bytecode.operand;

 			if (CiceroOptions.profileDynamicOpcodePairCounts) {
				ProfileOpcodePairCounts.profileDynamic(currentInstr, opcode);
 			}

  			if (CiceroOptions.traceBytecodeEvaluation) {
  				System.puts(Strings.format3("  +%d: %s %d\n", pc, opcode.name, bytecode.operand));
  				System.puts("    locals:\n");
  				for (i < locals.length) {
  					if (locals[i] == null) {
  						System.puts(Strings.format1("    %d: NULL\n", i));
  					} else {
  						System.puts(Strings.format2("    %d: %s\n", i, locals[i].display()));
  					}
  				}
  				System.puts("    stack:\n");
  				for (i < stack.top) {
  					System.puts("    ");
  					System.puts(stack.elems[i].display());
  					System.ln();
  				}
  				System.puts("    exn loc stack:\n");
  				for (i < handlers.top) {
  					System.puts("    ");
  					System.puts(Strings.format2("=> %d (%d)", handlers.elems[i].0, handlers.elems[i].1));
  					System.ln();
  				}
  				System.puts("--\n");
  			}
 

			currentInstr = Maybe.Just(opcode);
			pc += 4;
			match (opcode) {
				NOP => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, 0); // NOP has 0 zero execution time
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_CONST => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					stack.push(constants[operand]);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_GLOBAL => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def id = strings[operand];
					match (Globals.loadGlobal(id)){
						// `v` is a tuple -> (Object, int)
						Just(v) => {
							stack.push(v.0);

							if (CiceroOptions.useOptimizedGlobals) {
								// perform bytecode rewriting to replace `LOAD_GLOBAL` with `LOAD_GLOBAL_BY_INDEX`
								// `v.1` gives us the index into the `Globals.values` vector
								def global_index = v.1;
								// arguments: bytecode array, opcode index to replace, new opcode, index into `Global.values` vector
								rewriteBytecode(code, pc - 4, Opcode.LOAD_GLOBAL_BY_INDEX, global_index);
							}
						}
						Nothing => throw(Exceptions.unboundGlobal(id));
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_GLOBAL_BY_INDEX => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def value = Globals.loadGlobalByIndex(operand);
					stack.push(value);
					
					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_LOCAL => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def local = locals[operand];
					if (local == null)
						throw(Exceptions.unboundLocal(b.locals[operand]));
					else
						stack.push(local);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_LOCAL_SAFE => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					stack.push(locals[operand]);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_NONLOCAL => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def nonlocal = nonlocals[operand];
					if (CiceroOptions.sanityChecks) {
						if (nonlocal == null) {
							System.error("eval error", "nonlocal null");
						}
					}
					stack.push(nonlocal);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				STORE_GLOBAL => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def id = strings[operand];
					def top = stack.pop();
					// index into the `Globals.values` vector
					def global_index = Globals.storeGlobal(id, top);

					if (CiceroOptions.useOptimizedGlobals) {
						// perform bytecode rewriting to replace `STORE_GLOBAL` with `STORE_GLOBAL_BY_INDEX`
						// arguments: bytecode array, opcode index to replace, new opcode, index into `Global.values` vector
						rewriteBytecode(code, pc - 4, Opcode.STORE_GLOBAL_BY_INDEX, global_index);
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				STORE_GLOBAL_BY_INDEX => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.pop();
					Globals.storeGlobalByIndex(operand, top);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				STORE_LOCAL => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.pop();
					locals[operand] = top;

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				JUMP => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					pc += i24.view(operand);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				JUMP_IF_FALSE => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.pop();
					if (!top.isTrue()) pc += i24.view(operand);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				JUMP_IF_TRUE_PEEK => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.peek();
					if (!top.isTrue()) {
						stack.pop();
					} else {
						pc += i24.view(operand);
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				JUMP_IF_FALSE_PEEK => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.peek();
					if (top.isTrue()) {
						stack.pop();
					} else {
						pc += i24.view(operand);
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				RAISE => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.pop();
					assertType(ClassObjects.classStr, top);
					if (isExn()) {
						if (CiceroOptions.profileDynamicBytecode) {
							opExecTime = System.ticksNs() - opExecTime;
						    ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						    dispatchStartTime = System.ticksNs();
						}
						continue;
					}

					throw(StrObject.!(top).str);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				ASSERT_FUNC => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.peek();
					assertType(ClassObjects.classFunc, top);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				CALL => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					var args: Vector<Object> = Vector.new();
					for (i < operand) {
						args.put(stack.pop());
					}
					args.reverse(); // XXX reverse can be expensive, should do arithmetic on index instead

					def top = stack.pop();
					// function code
					def fv = FuncObject.!(top); // this cast succeeds because of ASSERT_FUNC
					def params = fv.params, code = fv.code;

					// evaluate argument values
					var argv: Array<(string, Object)>;

					if (fv.instanceOf(ClassObjects.classMethod)) {
						argv = Array.new(args.length + 1);
						for (i < args.length) {
							def arg = args[i];
							if (i < params.length) // avoid out of bounds but don't raise exception
								argv[i + 1] = (params[i], arg);
						}
						argv[0] = ("self", MethodObject.!(fv).obj);
					} else {
						argv = Array.new(args.length);
						for (i < args.length) {
							def arg = args[i];
							if (i < params.length) // avoid out of bounds but don't raise exception
								argv[i] = (params[i], arg);
						}
					}

					// arity check
					assertArity(params.length, args.length);
					if (isExn()) {
						if (CiceroOptions.profileDynamicBytecode) {
							opExecTime = System.ticksNs() - opExecTime;
						    ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						    dispatchStartTime = System.ticksNs();
						}
						continue;
					}

					// create new frame
					def frame = newFrame(fv.id, code, argv, fv.nonlocals);
 
					var startTime: int;

					if ((CiceroOptions.profileJumpOutcomes || CiceroOptions.profileCallerCalleePairs || CiceroOptions.profileInlineCaching) && BytecodeFrame.?(frame)) {
						BytecodeFrame.!(frame).associatedFunc = fv.metadata;
					}

					if (CiceroOptions.profileFunctionCalls || CiceroOptions.profileFuncObjectCalls || CiceroOptions.profileCallerCalleePairs) {
						startTime = System.ticksUs();
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicExecutionTime(opcode.tag, opExecTime);
					}

					// evaluate the frame (execute the function)
					frame.eval();
					
					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs();
					}

					if (CiceroOptions.profileFunctionCalls || CiceroOptions.profileFuncObjectCalls || CiceroOptions.profileCallerCalleePairs) {
						def inclusiveExecutionTime: int = System.ticksUs() - startTime; // in microseconds
						calleeExecutionTime += inclusiveExecutionTime;
						if (CiceroOptions.profileFunctionCalls) {
							def exclusiveExecutionTime : int = if(BytecodeFrame.?(frame),  inclusiveExecutionTime - BytecodeFrame.!(frame).calleeExecutionTime, inclusiveExecutionTime);
							ProfileFunctionCalls.profileFunctionCall(fv.metadata, inclusiveExecutionTime, exclusiveExecutionTime);
						}
						if (CiceroOptions.profileFuncObjectCalls) {
							def exclusiveExecutionTime : int = if(BytecodeFrame.?(frame),  inclusiveExecutionTime - BytecodeFrame.!(frame).calleeExecutionTime, inclusiveExecutionTime);
							ProfileFunctionCalls.profileFunctionObjectCall(fv.uid, fv.metadata.label, inclusiveExecutionTime, exclusiveExecutionTime);
						}
						if (CiceroOptions.profileCallerCalleePairs) {
							ProfileCallerCalleePairs.profilePair(associatedFunc, fv.metadata, inclusiveExecutionTime);
						}
					}

					if (frame.isExn()) {
						rethrow(frame.getExn());

						if (CiceroOptions.profileDynamicBytecode) {
							opExecTime = System.ticksNs() - opExecTime;
						    ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						    dispatchStartTime = System.ticksNs();
						}
						continue;
					}
					stack.push(frame.getValue());

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				TRY => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					handlers.push((pc + operand, stack.top));

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				CATCH => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					handlers.pop();

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				// stack manipulation
				POP => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					for (i < operand) stack.pop();

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				DUPE => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					// special path, operand = 0
					stack.push(stack.elems[stack.top - operand - 1]);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				SWAP => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.peek();
					def val = stack.elems[stack.top - operand - 1];
					stack.elems[stack.top - 1] = val;
					stack.elems[stack.top - operand - 1] = top;

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				// objects
				CREATE_CLASS => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def superclass = stack.pop();
					assertType(ClassObjects.classClass, superclass);
					if (isExn()) {
						if (CiceroOptions.profileDynamicBytecode) {
							opExecTime = System.ticksNs() - opExecTime;
						    ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						    dispatchStartTime = System.ticksNs();
						}
						continue;
					}

					def classhole = classholes[operand];
					stack.push(classhole(ClassObject.!(superclass)));

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				CREATE_OBJECT => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def top = stack.pop();
					assertType(ClassObjects.classClass, top);
					if (isExn()) {
						if (CiceroOptions.profileDynamicBytecode) {
							opExecTime = System.ticksNs() - opExecTime;
						    ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						    dispatchStartTime = System.ticksNs();
						}
						continue;
					}

					// duplicated code
					def clsObj = ClassObject.!(top);
					def obj = Objects.newObject(clsObj);

					def classes: Vector<ClassObject> = Vector.new();
					for (cls = clsObj; cls != null; cls = cls.superclass)
						classes.put(cls);
				
					// initialization order is from base class downwards, which
					// may involve reinitializing some fields
					for (cls in classes.reverse().extract()) {
						// initialize fields
						for (field in cls.classFields) {
							def name = field.0, expr = field.1;

							// XXX hackfix
							if (expr == null) continue;
							// create new frames here!
							def frame = newFrame(Strings.format2("%s.%s", cls.name, name), expr, [], []);

							if (CiceroOptions.profileDynamicBytecode) {
								opExecTime = System.ticksNs() - opExecTime;
								ProfileBytecode.profileDynamicExecutionTime(opcode.tag, opExecTime);
							}

							if ((CiceroOptions.profileJumpOutcomes || CiceroOptions.profileCallerCalleePairs || CiceroOptions.profileInlineCaching) && BytecodeFrame.?(frame)) {
								// treat the new frame as if the field expr is being evaluated in the current frame for caller-callee data
								BytecodeFrame.!(frame).associatedFunc = associatedFunc;
							}

							frame.eval();

							if (CiceroOptions.profileDynamicBytecode) {
								opExecTime = System.ticksNs();
							}

							if (frame.isExn()) {
								rethrow(frame.getExn());
								continue;
							}
							obj.setField(name, frame.getValue());
						}
						// call initializer
						if (cls.init != null) {
							def args = [("self", obj)];
							def code = cls.init;

							// create new frames here!
							def frame = newFrame(Strings.format1("%s.init", cls.name), code, args, []);

							if (CiceroOptions.profileDynamicBytecode) {
								opExecTime = System.ticksNs() - opExecTime;
								ProfileBytecode.profileDynamicExecutionTime(opcode.tag, opExecTime);
							}

							if ((CiceroOptions.profileJumpOutcomes || CiceroOptions.profileCallerCalleePairs || CiceroOptions.profileInlineCaching) && BytecodeFrame.?(frame)) {
								// treat the new frame as if the initializer expr is being evaluated in the current frame for caller-callee data
								BytecodeFrame.!(frame).associatedFunc = associatedFunc;
							}

							frame.eval();

							if (CiceroOptions.profileDynamicBytecode) {
								opExecTime = System.ticksNs();
							}

							if (frame.isExn()) {
								rethrow(frame.getExn());
								continue;
							}
						} 
					}
					stack.push(obj);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				LOAD_FIELD => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def obj = stack.pop();
					def field = strings[operand];

					if (CLOptions.CACHE.get()) {
  						cache = b.cache[(pc - 4) >> 2];
						
						def cls = obj.getClass();
						/* Inline cache */
						if (cache.fst == cls) {
							def res = obj.getFieldByIndex(cache.snd);
							if (CiceroOptions.useLazyMethods && res == null) {
								// if not yet initialized, must treat as cache miss
								stack.push(obj.getField(field));
								cache.snd = obj.getIndex(field);

								if (CiceroOptions.profileInlineCaching) {
									ProfileInlineCache.profileCacheMiss(b, pc-4, opcode.name, associatedFunc);
								}
							} else {
								// cache hit
								stack.push(res);

								if (CiceroOptions.profileInlineCaching) {
									ProfileInlineCache.profileCacheHit(b, pc-4);
								}
							}
						} else {
							// cache miss
							def v = obj.getField(field);
							if (v == null) {
								throw(Exceptions.missingField(obj, field));
							} else {
								cache.fst = cls;
								cache.snd = obj.getIndex(field);
								stack.push(v);
							}

							if (CiceroOptions.profileInlineCaching) {
								ProfileInlineCache.profileCacheMiss(b, pc-4, opcode.name, associatedFunc);
							}
						}
					} else {
						def v = obj.getField(field);
						if (v == null) {
							throw(Exceptions.missingField(obj, field));
						} else {
							stack.push(v);
						}
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				STORE_FIELD => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def val = stack.pop();
					def obj = stack.pop();
					def field = strings[operand];

					if (CLOptions.CACHE.get()) {
  						cache = b.cache[(pc - 4) >> 2];

						def cls = obj.getClass();
						// obj.initClass() is guaranteed to have executed
						// So, an index is guaranteed to exist for the field, given that the field exists.

						/* Inline Cache */
						if (cache.fst == cls){
							/* cache hit */
							// field exists since exception would have occured on initial cache miss otherwise
							obj.setFieldByIndex(cache.snd, val);

							if (CiceroOptions.profileInlineCaching) {
								ProfileInlineCache.profileCacheHit(b, pc-4);
							}
						} else {
							/* cache miss */
							if (!obj.setField(field, val)) {
								throw(Exceptions.missingField(obj, field));
							} else {
								cache.fst = cls;
								cache.snd = obj.getIndex(field);

								if (CiceroOptions.profileInlineCaching) {
									ProfileInlineCache.profileCacheMiss(b, pc-4, opcode.name, associatedFunc);
								}
							}
						}
					} else {
						if (!obj.setField(field, val)) {
							throw(Exceptions.missingField(obj, field));
						}
					}

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				CREATE_LIST => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def values: Vector<Object> = Vector.new();
					for (i < operand) {
						values.put(stack.pop());
					}
					values.reverse();

					def obj = ListObject.new();
					obj.list.puta(values.extract());

					stack.push(obj);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				CREATE_FUNC => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					def funchole = funcholes[operand];

					def nonlocals: Array<(string, Object)> = Array.new(funchole.nonlocals.length);

					def fn = FuncObjects.newFO(funchole.id, funchole.params, nonlocals, funchole.body, funchole.metadata);
					for (i = funchole.nonlocals.length - 1; i >= 0; i--) {
						// if the nonlocal is the function itself (for recursion) then do not
						// get it from the stack. you already have it!
						if (Strings.equal(funchole.nonlocals[i], funchole.id)) {
							nonlocals[i] = (funchole.id, fn);
						} else {
							nonlocals[i] = (funchole.nonlocals[i], stack.pop());
						}
					}

					stack.push(fn);

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
						dispatchStartTime = System.ticksNs();
					}
				}
				RETURN => {
					if (CiceroOptions.profileDynamicBytecode) {
						def dispatchEndTime = System.ticksNs();
						ProfileBytecode.profileDispatchCost(dispatchStartTime, dispatchEndTime);
						opExecTime = System.ticksNs();
					}

					// return value will be on top of the stack
					result = Result.Return(stack.pop());

					if (CiceroOptions.profileDynamicBytecode) {
						opExecTime = System.ticksNs() - opExecTime;
						ProfileBytecode.profileDynamicCountAndExecutionTime(opcode.tag, opExecTime);
					}
					return null;
				}
				//_ => System.error("eval error", "unsupported opcode");
			}

			if (CiceroOptions.profileJumpOutcomes) {
				match (opcode) {
				    JUMP, JUMP_IF_FALSE, JUMP_IF_TRUE_PEEK, JUMP_IF_FALSE_PEEK => {
					    def jump_taken = opcode_pc != (pc - 4);
					    ProfileJumpOutcomes.profileJump(b, opcode_pc, opcode.name, jump_taken, associatedFunc);
					}
					_ => {}
				}
			}
		}

		if (CiceroOptions.sanityChecks && stack.empty()) System.error("eval error", "stack is empty");
		if (CiceroOptions.traceBytecodeEvaluation) System.puts("RETURN\n");
		return stack.peek();
	}
}

/// Generic bytecode rewriting function
def rewriteBytecode(code: Array<byte>, op_index: int, new_op: Opcode, operand: int){
	// replace opcode
	code[op_index] = new_op.tag;

	// Little endian representation used to store the `operand` in bytecode
	code[op_index + 1] = byte.!(operand & 0xFF);
	code[op_index + 2] = byte.!((operand >> 8) & 0xFF);
	code[op_index + 3] = byte.!((operand >> 16) & 0xFF);
}

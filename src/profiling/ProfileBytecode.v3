component ProfileBytecode{

    def profileStaticCount(opTag: int){
		Profiling.staticCounts[opTag]++;
    }

    def profileDynamicCountAndExecutionTime(opTag: int, executionTime: int){
		Profiling.dynamicCounts[opTag]++;
		Profiling.dynamicOpExecutionTimes[opTag] += executionTime;
    }

    def profileDynamicExecutionTime(opTag: int, executionTime: int){
		Profiling.dynamicOpExecutionTimes[opTag] += executionTime;
    }

    def printStaticStats(){
		/* Output Cicero's profiling */
		var i = 0;
		var total = 0;
		System.puts("# STATIC COUNTS\n");
		System.puts("instruction, counts\n");
		for (op in Opcode.set.all) {
			def count = Profiling.staticCounts[i++];
			total += count;
			System.puts(Strings.format2("%s, %d\n", op.name, count));
		}
		System.puts(Strings.format1("# Total static bytecodes: %d\n", total));
    }

    def printDynamicStats(){
		var i = 0;
		var total = 0;
		var totalExecTime = 0L;
		System.puts("# DYNAMIC COUNTS:\n");
		System.puts("instruction, counts, total execution time(ns)\n");
		for (op in Opcode.set.all) {
			def execTime : long = Profiling.dynamicOpExecutionTimes[i];
			def count = Profiling.dynamicCounts[i++];
			total += count;
			totalExecTime += execTime;

			System.puts(Strings.format3("%s, %d, %s\n", op.name, count, ProfilingHelpers.longToString(execTime)));
		}
		System.puts(Strings.format1("# Total dynamic bytecodes: %d\n", total));
		System.puts(Strings.format1("# Total op execution time: %s nanoseconds\n", ProfilingHelpers.longToString(totalExecTime)));
    }
}
class Scanner {
	def STDIN = 0;
	def buffer: Vector<byte> = Vector<byte>.new();

	def nextLine() -> string {
		while (true) {
			def char = System.fileRead(STDIN);
			if (char == -1) {
				System.puts("EOF encountered\n");
				System.error("cicero", "EOF encountered\n");
			}
			if (char == '\n') return buffer.extract();
			buffer.put(byte.!(char));
		}
		return null;
	}
}

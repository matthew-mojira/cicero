export "fast:call_func7"       = WasmRuntime.callFunc7;
export "fast:call_func8"       = WasmRuntime.callFunc8;
export "fast:call_func9"       = WasmRuntime.callFunc9;
export "fast:call_func_rest"   = WasmRuntime.callFuncRest;
export "fast:push_arg"         = WasmRuntime.pushArg;
export "fast:pop_arg"          = WasmRuntime.popArg;
export "fast:get_result"       = WasmRuntime.getResult;
export "fast:set_result"       = WasmRuntime.setResult;
export "fast:create_func0"     = WasmRuntime.createFunc0;
export "fast:create_func1"     = WasmRuntime.createFunc1;
export "fast:create_func2"     = WasmRuntime.createFunc2;

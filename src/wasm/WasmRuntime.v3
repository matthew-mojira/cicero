export "fast:is_true"          = WasmRuntime.isTrue;
export "fast:is_false"         = WasmRuntime.isFalse;
export "fast:is_func"          = WasmRuntime.isFunc;
export "fast:is_class"         = WasmRuntime.isClass;
export "fast:is_string"        = WasmRuntime.isString;
export "fast:get_global"       = WasmRuntime.getGlobal;
export "fast:get_nonlocal"     = WasmRuntime.getNonlocal;
export "fast:set_global"       = WasmRuntime.setGlobal;
export "fast:raise_type"       = WasmRuntime.raiseTypeException;
export "fast:raise_string"     = WasmRuntime.raiseString;
export "fast:raise_field"      = WasmRuntime.raiseMissingField;
export "fast:call_func0"       = WasmRuntime.callFunc0;

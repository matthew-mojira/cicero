export "fast:create_func6"     = WasmRuntime.createFunc6;
export "fast:create_func7"     = WasmRuntime.createFunc7;
export "fast:create_func8"     = WasmRuntime.createFunc8;
export "fast:create_func9"     = WasmRuntime.createFunc9;
export "fast:get_field"        = WasmRuntime.getField;
export "fast:set_field"        = WasmRuntime.setField;
export "fast:create_class"     = WasmRuntime.createClass;
export "fast:create_object"    = WasmRuntime.createObject;
export "fast:create_list0"     = WasmRuntime.createList0;
export "fast:create_list1"     = WasmRuntime.createList1;
export "fast:create_list2"     = WasmRuntime.createList2;
export "fast:create_list3"     = WasmRuntime.createList3;

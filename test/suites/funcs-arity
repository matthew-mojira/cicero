; 17. left-to-right evaluation order with side effects.
; tick increments the global k and returns its new value;
; last26 returns the LAST extra, which must be 26 if evaluated in order.
(set k 0)
(func (tick) {
  (set-global k (+ k 1))
  k
})
(last26 (tick) (tick) (tick) (tick) (tick) (tick) (tick) (tick) (tick)
        (tick) (tick) (tick) (tick) (tick) (tick) (tick) (tick) (tick)
        (tick) (tick) (tick) (tick) (tick) (tick) (tick) (tick))
k
--
=> 0
=> <func 'tick'>
=> 26
=> 26

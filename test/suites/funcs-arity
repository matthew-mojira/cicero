; 20. recursion of a >9-arg function (10 frames pushing/popping)
(func (deep a b c d e f g h i n)
  (cond
    ((= n 0) a)
    (true (deep (+ a 1) b c d e f g h i (- n 1)))))
(deep 0 0 0 0 0 0 0 0 0 10)

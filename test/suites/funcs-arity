; 15. lambda / nested function with >9 params + nonlocal capture
(set captured 1000)
(func (outer)
  (lambda (a b c d e f g h i j) (+ captured j)))
(set f (outer))
(f 0 0 0 0 0 0 0 0 0 7)
--
=> 1000
=> <func 'outer'>
=> <lambda>
=> 1007

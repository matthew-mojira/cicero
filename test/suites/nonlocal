--
; mixed-type capture: int, string, list, lambda, null — order preserved
(func (cap-mixed)
  {
    (set i 42)
    (set s "hello")
    (set xs [1 2 3])
    (set fn (lambda (x) (+ x 1)))
    (set z ())
    (set b1 true)
    (set b2 false)
    (set i2 -7)
    (set s2 "world")
    (set xs2 [10 20])
    (lambda () [i s xs (fn 9) z b1 b2 i2 s2 xs2])
  })
((cap-mixed))
--
=> <func 'cap-mixed'>
=> [42, "hello", [1, 2, 3], 10, (), true, false, -7, "world", [10, 20]]
